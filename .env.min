# .env — МИНИМАЛЬНЫЙ набор для локального запуска

# ─── App ───────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ─── MongoDB (локальный через Docker) ─────────
MONGO_URI=mongodb://admin:password123@localhost:27017/ai-aggregator?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=password123

# ─── Redis (локальный через Docker) ────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ─── JWT (любая случайная строка для dev) ──────
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-chars
JWT_EXPIRATION=7d

# ─── Telegram Bot ─────────────────────────────
# Получи у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=your_dev_bot

# ─── AI Providers (хотя бы один для тестов) ────
# OpenRouter: зарегистрируйся на https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Остальные провайдеры — опционально, можно оставить пустыми
EVOLINK_API_KEY=
EVOLINK_BASE_URL=
KIE_API_KEY=
KIE_BASE_URL=
REPLICATE_API_KEY=

# ─── Платежи (опционально для dev) ─────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=

# ─── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ─── Rate Limiting ─────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120